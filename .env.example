# Resend API 키 (https://resend.com/api-keys 에서 발급)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# 문의 메일을 받을 관리자 주소 (여러 명이면 콤마로 구분)
INQUIRY_TO_EMAIL=admin@example.com

# 발신자 주소. Resend에서 인증한 도메인이어야 실제 발송됩니다.
# 도메인 인증 전 테스트는 onboarding@resend.dev 사용 가능 (본인에게만 발송됨)
INQUIRY_FROM_EMAIL=샤브광 가맹문의 <onboarding@resend.dev>

# ---------------------------------------------------------------------------
# 보도자료 관리 시스템 (Supabase) — 설정 방법은 supabase/README.md 참고
# ---------------------------------------------------------------------------

# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Project Settings → API → anon(public) key. RLS로 보호되므로 브라우저 노출 가능.
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Project Settings → API → service_role key. 서버 전용, 절대 커밋/클라이언트 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Cron이 /api/cron/publish-scheduled 호출 시 사용하는 임의의 긴 랜덤 문자열.
# 직접 생성해서 채우고, Vercel 프로젝트 환경변수에도 동일하게 등록한다.
CRON_SECRET=
