# Resend API 키 (https://resend.com/api-keys 에서 발급)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# 문의 메일을 받을 관리자 주소 (여러 명이면 콤마로 구분)
INQUIRY_TO_EMAIL=admin@example.com

# 발신자 주소. Resend에서 인증한 도메인이어야 실제 발송됩니다.
# 도메인 인증 전 테스트는 onboarding@resend.dev 사용 가능 (본인에게만 발송됨)
INQUIRY_FROM_EMAIL=샤브광 가맹문의 <onboarding@resend.dev>
